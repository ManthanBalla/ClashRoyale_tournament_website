RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx

# Optional aliases if you use test-specific names
# RAZORPAY_TEST_KEY_ID=rzp_test_xxxxxxxxxxxx
# RAZORPAY_TEST_KEY_SECRET=xxxxxxxxxxxxxxxx

EMAIL_HOST_USER=youremail@example.com
EMAIL_HOST_PASSWORD=your_app_password
REDIS_URL=redis://localhost:6379/0
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
DEFAULT_FROM_EMAIL=onboarding@resend.dev
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxx

# Cloudinary (recommended for media uploads on Render free tier)
# Example format:
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=
# Alternative separate keys (use these if URL format causes issues)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
